# Copy this file to .env and adjust as needed.

APP_NAME=Hexora
ENVIRONMENT=development

# SQLite by default. To use PostgreSQL instead:
# DATABASE_URL=postgresql://user:password@localhost:5432/hexora
DATABASE_URL=sqlite:///./storage/hexora.db

STORAGE_DIR=./storage

# Upload limits
MAX_UPLOAD_SIZE_MB=100
STRINGS_SCAN_LIMIT_BYTES=8388608

# Comma-separated list, or * for any origin (dev only)
ALLOWED_ORIGINS=*

# Optional API key gate for write endpoints (recommended in production)
API_KEY_ENABLED=false
API_KEY=change-me

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
